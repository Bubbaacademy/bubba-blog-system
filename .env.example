# ── Bubba Academy Content Agent — Environment Variables ──────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# On Render: add these in Dashboard → Environment → Add Environment Variable.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Anthropic Claude API key (content generation)
ANTHROPIC_API_KEY=sk-ant-...

# HubSpot Private App token (blog publishing)
# Create at: HubSpot → Settings → Integrations → Private Apps
HUBSPOT_TOKEN=pat-na2-...

# Google service-account credentials (Google Sheets access)
# Paste the FULL contents of credentials.json as a single-line JSON string.
# On Mac: pbcopy < credentials.json  → then paste here.
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ── OPTIONAL — override built-in defaults ────────────────────────────────────

# Google Sheet ID (default: Bubba Academy sheet)
# GOOGLE_SHEET_ID=1cYzI2qy2uEdI0T5xHPNNKXBP3czCuQAkiAeWeF2JwCM

# Google Sheet tab name (default: Sheet1)
# GOOGLE_SHEET_NAME=Sheet1

# Local fallback path to credentials.json (only used if GOOGLE_CREDENTIALS_JSON not set)
# GOOGLE_CREDENTIALS_FILE=credentials.json

# HubSpot numeric IDs (defaults match Bubba Academy production values)
# HUBSPOT_PORTAL_ID=243737166
# HUBSPOT_BLOG_ID=243260089053
# HUBSPOT_AUTHOR_ID=340728710883

# HubSpot embedded form (default: production form)
# HUBSPOT_FORM_ID=5d3a1165-5203-4ebd-a7de-8b344de6d961
# HUBSPOT_FORM_REGION=na2

# Set to "true" to skip live HubSpot publish (build + validate only)
# DRY_RUN=false

# Set to "true" to log the API payload without making a real POST
# HUBSPOT_MOCK_MODE=false
